<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.canvas.Canvas?>
<StackPane fx:id="mainApplicationLayout" prefHeight="380.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="editor.MainController">

    <HBox fx:id="mainWorkspace">

        <VBox spacing="30" styleClass="left-sidebar">
            <VBox spacing="8">
                <Label styleClass="app-title" text="Vyshyvanka Editor" />
                <Label styleClass="author-title" text="Created by Pulov Mykhailo" />
            </VBox>
            <VBox styleClass="symmetry-controls" spacing="10">
                <Label styleClass="section-title" text="Symmetry Controls" />

                <HBox fx:id="horizontalSymmetryBox" styleClass="symmetry-button" spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="horizontalSymmetryBtn" styleClass="symmetry-text" text="Horizontal" />

                    <Region HBox.hgrow="ALWAYS" />

                    <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                        <image><Image url="@/icons/horizont.png"/></image>
                    </ImageView>
                </HBox>

                <HBox fx:id="verticalSymmetryBox" styleClass="symmetry-button" spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="verticalSymmetryBtn" styleClass="symmetry-text" text="Vertical" />

                    <Region HBox.hgrow="ALWAYS" />

                    <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                        <image><Image url="@/icons/vertical.png"/></image>
                    </ImageView>
                </HBox>
            </VBox>

            <VBox styleClass="active-thread" spacing="12">
                <Label styleClass="section-title" text="Active Thread" />
                <VBox spacing="10" alignment="CENTER">
                    <HBox styleClass="thread-colors" spacing="10">
                        <StackPane fx:id="colorCircle1" styleClass="color-circle" style="-fx-background-color: #D97757;" />
                        <StackPane fx:id="colorCircle2" styleClass="color-circle" style="-fx-background-color: #F4AAA9;" />
                        <StackPane fx:id="colorCircle3" styleClass="color-circle, color-empty">
                            <Label text="+" styleClass="color-empty-text" />
                        </StackPane>
                        <StackPane fx:id="colorCircle4" styleClass="color-circle, color-empty">
                            <Label text="+" styleClass="color-empty-text" />
                        </StackPane>
                    </HBox>
                    <HBox styleClass="thread-colors" spacing="10">
                        <StackPane fx:id="colorCircle5" styleClass="color-circle, color-empty">
                            <Label text="+" styleClass="color-empty-text" />
                        </StackPane>
                        <StackPane fx:id="colorCircle6" styleClass="color-circle, color-empty">
                            <Label text="+" styleClass="color-empty-text" />
                        </StackPane>
                        <StackPane fx:id="colorCircle7" styleClass="color-circle, color-empty">
                            <Label text="+" styleClass="color-empty-text" />
                        </StackPane>
                        <StackPane fx:id="colorCircle8" styleClass="color-circle, color-empty">
                            <Label text="+" styleClass="color-empty-text" />
                        </StackPane>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>

        <BorderPane HBox.hgrow="ALWAYS">
            <top>
                <HBox styleClass="top-nav-bar">
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox spacing="25">
                        <HBox spacing="20" styleClass="nav-controls">
                            <Label fx:id="createNavLabel" styleClass="nav-link" text="Create" />
                            <Label fx:id="saveNavLabel" styleClass="nav-link" text="Save" />
                            <Label fx:id="openNavLabel" styleClass="nav-link" text="Open" />
                        </HBox>
                        <HBox styleClass="nav-controls">
                            <Label fx:id="infoNavLabel" styleClass="nav-link" text="Info" />
                        </HBox>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>
            </top>

            <center>
                <StackPane fx:id="canvasContainer">
                    <StackPane fx:id="mainCanvasView" styleClass="main-canvas-view">
                        <Canvas fx:id="gridCanvas" />
                        <Canvas fx:id="stitchCanvas" />
                        <VBox fx:id="createMenu" styleClass="create-menu" spacing="10" alignment="CENTER">
                            <StackPane>
                                <Label text="Create New" styleClass="section-title" style="-fx-font-size: 16px; -fx-padding: 0; -fx-text-fill: -fx-text-primary"/>
                                <Label fx:id="closeCreateMenuBtn" styleClass="close-btn" StackPane.alignment="TOP_RIGHT">
                                    <StackPane.margin>
                                        <javafx.geometry.Insets top="-5" right="-5" bottom="0" left="0"/>
                                    </StackPane.margin>
                                    <graphic>
                                        <ImageView fitWidth="14" fitHeight="14" preserveRatio="true">
                                            <image><Image url="@/icons/close.png"/></image>
                                        </ImageView>
                                    </graphic>
                                </Label>
                            </StackPane>
                            <TextField fx:id="projectNameField" promptText="Project name" styleClass="create-name-field" />
                            <VBox styleClass="grid-size-controls" spacing="10">
                                <Label styleClass="section-title" text="Grid Size" />
                                <HBox alignment="CENTER" spacing="15">
                                    <Label fx:id="gridMinusBtn" styleClass="grid-size-btn">
                                        <graphic>
                                            <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                                                <image><Image url="@/icons/minus.png"/></image>
                                            </ImageView>
                                        </graphic>
                                    </Label>
                                    <Label fx:id="gridSizeLabel" styleClass="grid-size-text" text="64 x 64" />
                                    <Label fx:id="gridPlusBtn" styleClass="grid-size-btn">
                                        <graphic>
                                            <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                                                <image><Image url="@/icons/plus.png"/></image>
                                            </ImageView>
                                        </graphic>
                                    </Label>
                                </HBox>
                            </VBox>
                            <Button fx:id="createGridBtn" text="Create" styleClass="create-grid-btn" />
                        </VBox>
                    </StackPane>
                </StackPane>
            </center>

            <bottom>
                <HBox spacing="40" styleClass="bottom-toolbar">
                    <Label fx:id="clearCanvasBtn" styleClass="bottom-btn" text="Clear Canvas" />
                    <Label fx:id="eraserBtn" styleClass="bottom-btn" text="Eraser" />
                    <Label styleClass="bottom-btn, animate-btn" text="Animate" />
                </HBox>
            </bottom>
        </BorderPane>

    </HBox>

    <Label fx:id="autoSaveLabel" text="✓ Autosaved" styleClass="autosave-toast" StackPane.alignment="TOP_RIGHT" visible="false">
        <StackPane.margin>
            <javafx.geometry.Insets top="15" right="20" bottom="0" left="0"/>
        </StackPane.margin>
    </Label>

    <VBox fx:id="loadingScreen" styleClass="loading-screen" spacing="20">
        <VBox styleClass="loading-img"></VBox>
        <Label styleClass="author-loading-text" text="Created by Pulov Mykhailo" />
        <Label styleClass="loading-text" text="LOADING WORKSPACE..." />
        <ProgressBar fx:id="loadingBar" progress="0.0" prefWidth="400.0" styleClass="loading-bar"/>
    </VBox>

</StackPane>
